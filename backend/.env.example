SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
PORT=3001

# AI hint chatbot (Gemini) — server-side only, never exposed to the browser
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
CHAT_RATE_LIMIT_PER_MIN=15
CHAT_MAX_MESSAGES_PER_QUESTION=40

# Photo-based AI grading (Gemini vision) — reuses GEMINI_API_KEY / GEMINI_MODEL
GRADE_RATE_LIMIT_PER_MIN=5
GRADE_MAX_IMAGES=5
GRADE_MAX_IMAGE_MB=8
