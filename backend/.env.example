SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
PORT=3001

# AI hint chatbot (Gemini) — server-side only, never exposed to the browser
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
CHAT_RATE_LIMIT_PER_MIN=15
CHAT_MAX_MESSAGES_PER_QUESTION=40

# Photo-based AI grading (Gemini vision) — reuses GEMINI_API_KEY / GEMINI_MODEL
GRADE_RATE_LIMIT_PER_MIN=5
GRADE_MAX_IMAGES=5
GRADE_MAX_IMAGE_MB=8

# Gemini gateway pacing — match these to the key's real limits when switching model/tier
# (check https://aistudio.google.com/rate-limit). Defaults = gemini-2.5-flash free tier.
AI_RPM_LIMIT=10
AI_RPD_LIMIT=250
# What we actually release per minute (kept under AI_RPM_LIMIT so bursts never 429)
AI_OUTBOUND_RPM=8
# Per-user cooldowns between accepted AI requests (typed re-grades are exempt)
AI_CHAT_COOLDOWN_S=5
AI_GRADE_COOLDOWN_S=60
# Max time a request may queue before failing with "AI is busy"
AI_CHAT_QUEUE_MAX_WAIT_S=30
AI_GRADE_QUEUE_MAX_WAIT_S=120
AI_QUEUE_MAX_LENGTH=50

# "Upload via phone" QR pairing (in-memory, Socket.IO live transfer)
PAIR_TTL_MIN=10
PAIR_RATE_LIMIT_PER_MIN=30

#service account JSON
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
CORS_ORIGIN=http://localhost:5173

# Stripe — server-side only, never exposed to the browser
# Dev: run `stripe listen --forward-to localhost:3001/api/billing/webhook` → copy printed whsec_... into STRIPE_WEBHOOK_SECRET
# Prod: set webhook endpoint in Stripe Dashboard → Developers → Webhooks → use the whsec_... it gives you
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_1Tp1yVKGxkiNQqZhbHMAkSye
STRIPE_PRICE_ANNUAL=price_1Tp1yXKGxkiNQqZh4CPPsbK7
STRIPE_PRICE_MONTHLY_PAYNOW=price_1Tp1yYKGxkiNQqZhHimzyTTq
STRIPE_PRICE_ANNUAL_PAYNOW=price_1Tp1yZKGxkiNQqZhAgumFiMx